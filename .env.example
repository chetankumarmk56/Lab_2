# ─── Claude Agent SDK ───────────────────────────────────────────────
# Required to run the lab agents. Get one from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model the agents run on. Default is the most capable Opus tier.
# Use claude-sonnet-5 or claude-haiku-4-5 to cut cost during development.
CLAUDE_MODEL=claude-opus-4-8

# ─── PostgreSQL (used from Lab 2 onward) ────────────────────────────
# NOTE: host port is 5433, NOT 5432 — your machine already runs a local
# PostgreSQL 18 service on 5432, so the Docker container uses 5433 to
# avoid a conflict. See docker-compose.yml.
DATABASE_URL=postgresql://labs:labs_dev_pw@localhost:5433/agentic_labs

# Read-only role used by the Lab 2 query tool (created by backend/db/seed.py).
READONLY_DATABASE_URL=postgresql://labs_readonly:labs_readonly_pw@localhost:5433/agentic_labs
